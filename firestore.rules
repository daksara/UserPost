rules_version = '2';

// Security rules for Pendar.
// Deploy with: firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isGranter() {
      // Badge granting is reserved for verified (official) accounts.
      return signedIn()
        && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.is_verified == true;
    }

    // ── Profiles ─────────────────────────────────────────────────
    match /profiles/{userId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.username is string
        && request.resource.data.username.matches('^[a-zA-Z0-9_]{3,20}$')
        // New accounts can never self-assign badges — except the automatic
        // OG (early adopter) badge given to everyone at signup
        && request.resource.data.get('is_verified', false) == false
        && (request.resource.data.get('badge_type', null) == null
            || request.resource.data.get('badge_type', null) == 'og');

      allow update: if signedIn() && (
        // Owner may edit own profile fields, but not badges/username
        (
          request.auth.uid == userId
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['photo_url', 'bio', 'twitter', 'telegram', 'tip_ca'])
        )
        // Verified accounts may grant/revoke badges on others
        || (
          isGranter()
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['badge_type'])
        )
      );

      allow delete: if signedIn() && request.auth.uid == userId;
    }

    // ── Username index ───────────────────────────────────────────
    // Public availability check needs `get`; never allow listing.
    // Docs contain only { uid } for new accounts (no email — see signUp).
    match /usernames/{username} {
      allow get: if true;
      allow list: if false;
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // ── Posts ────────────────────────────────────────────────────
    match /posts/{postId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.user_id == request.auth.uid
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 500
        // Posts live at most 24 hours
        && request.resource.data.expires_at is timestamp
        && request.resource.data.expires_at <= request.time + duration.value(24, 'h');

      function counterDelta(field) {
        return request.resource.data.get(field, 0) - resource.data.get(field, 0);
      }

      // Anyone signed in may bump the counters (likes/comments) by exactly 1
      allow update: if signedIn()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['like_count', 'comment_count'])
        && counterDelta('like_count') >= -1 && counterDelta('like_count') <= 1
        && counterDelta('comment_count') >= -1 && counterDelta('comment_count') <= 1;

      allow delete: if signedIn() && resource.data.user_id == request.auth.uid;

      match /comments/{commentId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.resource.data.user_id == request.auth.uid
          && request.resource.data.body is string
          && request.resource.data.body.size() > 0
          && request.resource.data.body.size() <= 280;
        allow delete: if signedIn() && (
          resource.data.user_id == request.auth.uid
          // Post owner may also remove comments on their post
          || get(/databases/$(database)/documents/posts/$(postId)).data.user_id == request.auth.uid
        );
        allow update: if false;
      }
    }

    // ── Per-user data ────────────────────────────────────────────
    match /users/{userId}/liked_posts/{postId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    // Inbox entry doc id == the conversation partner's uid, so the
    // partner needs write access to deliver "new message" entries.
    match /users/{userId}/inbox/{partnerId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow write: if signedIn()
        && (request.auth.uid == userId || request.auth.uid == partnerId);
    }

    // ── Direct messages ──────────────────────────────────────────
    // Conversation id is "{uidA}_{uidB}" with uids sorted.
    match /conversations/{convId}/messages/{messageId} {
      function isParticipant() {
        return signedIn() && request.auth.uid in convId.split('_');
      }

      allow read: if isParticipant();

      allow create: if isParticipant()
        && request.resource.data.from_id == request.auth.uid
        && request.resource.data.to_id in convId.split('_')
        && request.resource.data.to_id != request.auth.uid
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 1000;

      allow update: if isParticipant() && (
        // Recipient marks as read
        (
          resource.data.to_id == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read_at'])
        )
        // Sender soft-deletes own message
        || (
          resource.data.from_id == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deleted_at'])
        )
      );

      allow delete: if false;
    }

    // ── Airdrop tracker (Pendar) ─────────────────────────────────
    // Catatan airdrop privat milik tiap user. Hanya pemilik yang bisa
    // baca/tulis. Query selalu difilter where('user_id','==',uid).
    match /airdrops/{airdropId} {
      allow read: if signedIn() && resource.data.user_id == request.auth.uid;

      allow create: if signedIn()
        && request.resource.data.user_id == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 200
        && request.resource.data.tasks is list;

      // Pemilik boleh ubah, tapi user_id tidak boleh dipindahtangankan.
      allow update: if signedIn()
        && resource.data.user_id == request.auth.uid
        && request.resource.data.user_id == request.auth.uid;

      allow delete: if signedIn() && resource.data.user_id == request.auth.uid;
    }

    // Deny everything not matched above
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
